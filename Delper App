<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ecosystem Rewards Portal</title>
    <!-- Chart.js for data visualization -->
    <script src="https://jsdelivr.net"></script>
    <style>
        :root {
            --primary: #4f46e5;
            --primary-light: #e0e7ff;
            --secondary: #06b6d4;
            --secondary-light: #ecfeff;
            --background: #f8fafc;
            --surface: #ffffff;
            --text-main: #0f172a;
            --text-muted: #64748b;
            --success: #10b981;
            --border: #e2e8f0;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        body {
            background-color: var(--background);
            color: var(--text-main);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 10px;
        }

        /* Mobile Frame Container */
        .phone-container {
            width: 100%;
            max-width: 410px;
            height: 840px;
            background: var(--surface);
            border-radius: 36px;
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.15);
            overflow: hidden;
            display: flex;
            flex-direction: column;
            position: relative;
            border: 10px solid #1e293b;
        }

        /* Base Screen Setup */
        .screen {
            display: none;
            flex-direction: column;
            height: 100%;
            width: 100%;
            padding: 24px;
            overflow-y: auto;
        }

        .screen.active {
            display: flex;
        }

        /* Typography */
        h2 {
            font-size: 22px;
            font-weight: 700;
            margin-bottom: 8px;
            color: var(--text-main);
        }

        h3 {
            font-size: 16px;
            font-weight: 600;
            margin-bottom: 12px;
        }

        p {
            font-size: 14px;
            line-height: 1.5;
            color: var(--text-muted);
            margin-bottom: 16px;
        }

        /* Disclaimer Gate Requirements */
        .disclaimer-scroll-box {
            background: #f1f5f9;
            padding: 16px;
            border-radius: 12px;
            max-height: 220px;
            overflow-y: auto;
            border: 1px solid var(--border);
            font-size: 13px;
            line-height: 1.6;
            margin-bottom: 16px;
            color: #334155;
        }

        .checkbox-group {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin-bottom: 20px;
        }

        .checkbox-label {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            font-size: 13px;
            cursor: pointer;
            line-height: 1.4;
            color: #334155;
        }

        .checkbox-label input {
            width: 18px;
            height: 18px;
            accent-color: var(--primary);
            margin-top: 2px;
            flex-shrink: 0;
        }

        /* Buttons & Forms */
        .btn {
            background: var(--primary);
            color: white;
            border: none;
            padding: 14px;
            border-radius: 12px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            width: 100%;
            text-align: center;
            transition: background 0.2s, opacity 0.2s;
        }

        .btn:disabled {
            background: var(--border);
            color: var(--text-muted);
            cursor: not-allowed;
        }

        .btn-google {
            background: #ffffff;
            color: #475569;
            border: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-bottom: 20px;
            font-weight: 500;
        }

        .btn-google.gate-auth {
            margin-bottom: 14px;
            border-color: var(--primary);
            color: var(--primary);
            background: var(--primary-light);
        }

        .auth-status-badge {
            font-size: 12px;
            font-weight: 600;
            color: var(--success);
            text-align: center;
            margin-bottom: 16px;
            display: none;
        }

        .input-wrapper {
            margin-bottom: 16px;
        }

        label {
            display: block;
            font-size: 11px;
            font-weight: 700;
            margin-bottom: 6px;
            text-transform: uppercase;
            color: var(--text-muted);
            letter-spacing: 0.5px;
        }

        input[type="text"], input[type="tel"], input[type="number"], select {
            width: 100%;
            padding: 12px;
            border: 1px solid var(--border);
            border-radius: 8px;
            font-size: 15px;
            background: #f8fafc;
            color: var(--text-main);
            outline: none;
        }

        input:focus, select:focus {
            border-color: var(--primary);
        }

        /* Dashboard Elements */
        .dash-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .user-avatar {
            width: 38px;
            height: 38px;
            background: var(--primary-light);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            color: var(--primary);
        }

        .balance-hero-card {
            background: linear-gradient(135deg, #4f46e5, #7c3aed);
            color: white;
            padding: 22px;
            border-radius: 20px;
            margin-bottom: 20px;
            box-shadow: 0 10px 15px -3px rgba(79, 70, 229, 0.3);
        }

        .balance-value {
            font-size: 34px;
            font-weight: 700;
            margin-top: 4px;
        }

        .metric-split-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-bottom: 20px;
        }

        .metric-card {
            background: #f8fafc;
            padding: 14px;
            border-radius: 12px;
            border: 1px solid var(--border);
        }

        .metric-number {
            font-size: 18px;
            font-weight: 700;
            color: var(--text-main);
            margin-top: 4px;
        }

        .timeline-tracker {
            margin-bottom: 24px;
            background: #f8fafc;
            padding: 14px;
            border-radius: 12px;
            border: 1px solid var(--border);
        }

        .bar-container {
            height: 8px;
            background: var(--border);
            border-radius: 4px;
            overflow: hidden;
            margin-top: 8px;
        }

        .bar-fill {
            height: 100%;
            background: var(--success);
            width: 43%;
        }

        .task-card {
            background: var(--surface);
            border: 1px solid var(--border);
            padding: 16px;
            border-radius: 12px;
            margin-bottom: 12px;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 14px;
            transition: transform 0.2s, border-color 0.2s;
        }

        .task-card:hover {
            border-color: var(--primary);
            transform: translateY(-1px);
        }

        .task-icon {
            font-size: 24px;
            padding: 10px;
            border-radius: 10px;
            background: var(--primary-light);
        }

        /* Fixed Navigation */
        .bottom-navigation {
            margin-top: auto;
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            border-top: 1px solid var(--border);
            padding-top: 12px;
            background: var(--surface);
        }

        .nav-button {
            display: flex;
            flex-direction: column;
            align-items: center;
            font-size: 11px;
            color: var(--text-muted);
            cursor: pointer;
            gap: 4px;
        }

        .nav-button.active {
            color: var(--primary);
            font-weight: 600;
        }

        .nav-button-icon {
            font-size: 18px;
        }

        /* Allied Marketplace */
        .marketplace-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin-top: 8px;
        }

        .vendor-item-card {
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 14px;
            text-align: center;
            background: #f8fafc;
        }

        .vendor-avatar {
            font-size: 28px;
            margin-bottom: 8px;
        }

        .discount-tag {
            background: var(--secondary-light);
            color: #0891b2;
            font-size: 11px;
            font-weight: 600;
            padding: 3px 8px;
            border-radius: 6px;
            display: inline-block;
            margin-top: 6px;
        }
    </style>
</head>
<body>

    <div class="phone-container">

        <!-- SCREEN 1: SYSTEM DISCLAIMER GATE (Active First) -->
        <div id="screen-gate" class="screen active">
            <div>
                <h2>Ecosystem Disclosure & Rules</h2>
                <p>Welcome. Please authenticate your identity and acknowledge the community compliance terms to enter the application.</p>
